APP_NAME="October CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=en

ACTIVE_THEME=laravelmix
BACKEND_URI=/admin
BACKEND_TURBO_ROUTER=false
CMS_ROUTE_CACHE=false
CMS_ASSET_CACHE=false
CMS_SAFE_MODE=false
LINK_POLICY=detect
DEFAULT_FILE_MASK=775
DEFAULT_FOLDER_MASK=775
LOG_DEPRECATIONS=false

# Local: sqlite (use absolute path locally, Docker path in production)
DB_CONNECTION=sqlite
# Local dev:  DB_DATABASE=/absolute/path/to/project/storage/database.sqlite
# Docker/Cloud Run: DB_DATABASE=/var/www/html/storage/database.sqlite
DB_DATABASE=storage/database.sqlite

# Cloud SQL (uncomment for production)
# DB_CONNECTION=mysql
# DB_HOST=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# DB_PORT=3306
# DB_DATABASE=october
# DB_USERNAME=october
# DB_PASSWORD=

LOG_CHANNEL=stderr
BROADCAST_DRIVER=log
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@octobercms.tld
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
